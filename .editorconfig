# EditorConfig — see https://editorconfig.org
# Keeps formatting consistent across editors.

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

[*.md]
# Markdown can use trailing spaces to force a line break.
trim_trailing_whitespace = false

[*.php]
indent_size = 4

[Makefile]
indent_style = tab
